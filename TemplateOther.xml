	<coll name="HorasExpedientes" sql="SELECT 
		CONCAT('  ',ROUND(HORAS_VIAJE_FINALES,2)) AS MAP_HORAS_VIAJE_FINALES,
		CONCAT('  ',ROUND(HORAS_TRABAJO_FINALES,2)) AS MAP_HORAS_TRABAJO_FINALES,
		CONCAT('  ',NUMEROORDEN) AS MAP_NUMEROORDEN,
		CONCAT('  ',EXPEDIENTE) AS MAP_EXPEDIENTE,
		CONCAT('  ',FECHA) AS MAP_FECHA
		FROM (SELECT SUM(HORAS_VIAJE_FINALES) AS HORAS_VIAJE_FINALES,SUM(HORAS_TRABAJO_FINALES) AS HORAS_TRABAJO_FINALES,
		NUMEROORDEN,EXPEDIENTE,DATE_FORMAT(FECHA, '%Y-%m-%d') AS FECHA 
		from gen_ot_estados_ex goee WHERE BAJA=0 group by NUMEROORDEN,EXPEDIENTE,DATE_FORMAT(FECHA, '%Y-%m-%d')) p"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmTp2" width="100%" >
			<frame name="frmTITLE_PROPIEDAD2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#ffffff">
				<prop name="MAP_FECHA" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
