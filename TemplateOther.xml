<?xml version="1.0" encoding="utf-8"?> 
<xml>
	<!-- CABECERA -->				
	<coll name="coll1" sql="select CONCAT('  ',O.NUMEROORDEN) AS MAP_NUMEROORDEN,
	CONCAT('  ',O.DESCRIPCION) AS MAP_DESCRIPCION,
	CONCAT('  ',O.OBSERVACIONES) AS MAP_OBSERVACIONES,
						concat('RESUMEN OT - ',O.NUMEROORDEN) AS MAP_TITULO,
						'/var/www/vhosts/xoneideintcore.com/core/xonemonitorcore/Monitor/ide_iberdrola.png' AS MAP_LOGO,
                        O.ID as ID,
						O.NUMEROORDEN,
                        IFNULL(O.PDF_CREADO,0) AS PDF_CREADO,
						O.CLAVE_GRUPO_HR,
						O.CONTADOR_GRUPOS_HR,
						concat('  ', O.CLASE_ORDEN,' - ',CO.DESCRIPCION) AS MAP_CLASE_ORDEN,
						concat('  ', O.CLASE_ACTIVIDAD,' - ',CA.DESCRIPCION) AS MAP_CLASE_ACTIVIDAD,
						concat('  ',ROUND(ifnull(H.HORAS_VIAJE_FINALES,0), 2)) AS MAP_HORAS_DESPLAZAMIENTO,
						concat('  ',ROUND(ifnull(H.HORAS_TRABAJO_FINALES,0),2)) AS MAP_HORAS_INTERVENCION,	

						concat('  ',CASE WHEN O.UBICACION_TECNICA IS NOT NULL THEN concat(O.UBICACION_TECNICA,' - ') ELSE '' END,O.NOMBRE_UBICACION) AS MAP_INSTALACION,												

						'Riesgos' as MAP_TITLE_RIESG,
						(SELECT count(*) FROM gen_ar_ot_riesgos ri INNER JOIN gen_ar_maestro_riesgos mri ON ri.COD_TIP_RIESGO = mri.COD_TIP_RIESGO WHERE ri.NUMEROORDEN = O.NUMEROORDEN ) as MAP_VER_RIESG,
						
		'Robos' as MAP_TITLE_Robos_OT_2,
		(SELECT count(*) FROM gen_ot_cabecera cab INNER JOIN gen_rob_ot_robos rob ON rob.NUMEROORDEN=cab.NUMEROORDEN WHERE cab.CLASE_ORDEN ='DROB' and cab.CLASE_ACTIVIDAD in ('DB4','DB5') and cab.NUMEROORDEN=O.NUMEROORDEN) as MAP_VER_ROBOS_OT,
		'Fugas a tierra' as MAP_TITLE_FUGAS_TIERRA,
		(SELECT count(*) FROM gen_avf_ot_fugas_tierra fug INNER JOIN gen_ot_cabecera cab ON cab.NUMEROORDEN = fug.NUMEROORDEN WHERE cab.NUMEROORDEN = O.NUMEROORDEN) as MAP_VER_FUGAS_TIERRA_OT

,
		'Estudio de Inundabilidad' AS MAP_TITLE_INUNDABILIDAD,
		(SELECT COUNT(1) FROM gen_inundabilidad_ot_bloques_rev ir
		 WHERE ir.NUMEROORDEN = O.NUMEROORDEN AND ir.revisado = 1
		   AND O.CLASE_ORDEN IN ('DPRP','DPRN')
		   AND O.UBICACION_TECNICA LIKE 'C%') AS MAP_VER_INUNDABILIDAD,
		O.UBICACION_TECNICA AS MAP_UBICACION_TECNICA						from gen_ot_cabecera O
						LEFT JOIN gen_maestro_clase_orden CO ON CO.CODIGO = O.CLASE_ORDEN
						LEFT JOIN (SELECT SUM(HORAS_VIAJE_FINALES) AS HORAS_VIAJE_FINALES,SUM(HORAS_TRABAJO_FINALES) AS HORAS_TRABAJO_FINALES,NUMEROORDEN from gen_ot_estados_ex goee WHERE BAJA=0 GROUP BY NUMEROORDEN) H ON H.NUMEROORDEN = O.NUMEROORDEN
						LEFT JOIN gen_maestro_clase_actividad CA ON CA.CODIGO = O.CLASE_ACTIVIDAD" lmargin="5%" rmargin="5%" tmargin="5%" bmargin="5%" 
				filter="O.ID=##ID## order by O.ID DESC" entry-point="true" show-header="false" show-pagination="true" show-file-date-creation="true"> 
				<footer height="20p">
					<prop name="MAP_TITLE_FOOTER" type="TL" width="98%" height="15p" title="La revisión se ha realizado según lo indicado en el manual técnico MT 2.04.02" align="center" font-size="10" lines="1" forecolor="#000000" lmargin="1%"/>
				</footer>
						
				<prop name="MAP_TITULO" type="T" lmargin="8%" tmargin="5p" width="64%" align="center" fontbold="true" font-size="18" copy-to-all-pages="true"/>
				<prop name="MAP_LOGO" 	type="IMG" 	lmargin="19%" width="9%" align="right"  copy-to-all-pages="true" newline="false" keep-aspect-ratio="true"/>
			
				<frame name="frmDatosIdentificativos" width="100%" border-color="#000000" tmargin="15p">

					<frame name="frmTITLE_DATOS_IDENTIFICACION" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_DATOS_IDENTIFICACION" type="TL" width="98%" height="15p" title="Datos identificativos" align="center" 
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" border-color="#000000" forecolor="#ffffff" lmargin="1%"/>
					</frame>
					
					<prop name="MAP_TL_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Numero de OT:  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
					<prop name="MAP_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
			
					<prop name="MAP_TL_CLASE_ORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Clase de Orden: " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
					<prop name="MAP_CLASE_ORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
					<prop name="MAP_TL_CLASE_ACTIVIDAD" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Clase de Actividad: " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_CLASE_ACTIVIDAD" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>
				
					<prop name="MAP_TL_INSTALACION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Instalacion: " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_INSTALACION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>
					
					<prop name="MAP_TL_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Descripción: " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>
							
					<prop name="MAP_TL_OBSERVACIONES" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Observaciones: " align="center" bgcolor="#ffffff" lines="2" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_OBSERVACIONES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>
					
				</frame>

				<frame name="frmExpedientes" width="100%" tmargin="15p" disablevisible="MAP_EXTERNO=1">
					<frame name="frmEXPEDIENTES" disablevisible="MAP_EXTERNO=1" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_EXPEDIENTES" disablevisible="MAP_EXTERNO=1" type="TL" width="98%" height="15p" title="Expedientes" align="center"
								bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>
				
				<prop name="HorasExpedientes" disablevisible="MAP_EXTERNO=1" content="@HorasExpedientes"  type="Z"/>
				<content name="@HorasExpedientes" src="HorasExpedientes" filter="p.NUMEROORDEN='##FLD_NUMEROORDEN##' ORDER BY FECHA ASC"/>
						
				<break-page />

				<frame name="frmRiesgos" width="100%" tmargin="15p" >
					<frame name="frmRIESG"  border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_RIESG" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>
	
				<prop name="MAP_LITERAL_ACR" disablevisible="MAP_VER_RIESG&gt;0" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="TL" title="  Sin riesgos  " width="100%" height="15p"	align="left" lines="1" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
	
				<prop name="MAP_RIESGOS" content="@Riesgos" disablevisible="MAP_VER_RIESG=0" type="Z"/>
				<content name="@Riesgos" src="Riesgos" filter="ri.NUMEROORDEN='##FLD_NUMEROORDEN##'"/>

				<break-page />

				<frame name="frmRobos_OT" width="100%" tmargin="15p" >
					<frame name="frmRobos_OT_2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_Robos_OT_2" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>
	
				<prop name="MAP_LITERAL_ROBOS_OT" disablevisible="MAP_VER_ROBOS_OT&gt;0" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="TL" title="  Sin robos  " width="100%" height="15p"	align="left" lines="1" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
	
				<prop name="MAP_ROBOS_OT" content="@Robos_OT" disablevisible="MAP_VER_ROBOS_OT=0" type="Z"/>
				<content name="@Robos_OT" src="Robos_OT" filter="cab.CLASE_ORDEN ='DROB' and cab.CLASE_ACTIVIDAD in ('DB4','DB5') and cab.NUMEROORDEN='##FLD_NUMEROORDEN##'"/>
				
				<break-page />

				<frame name="frmFUGAS_TIERRA" width="100%" tmargin="15p" >
					<frame name="frmFUGAS_TIERRA_2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_FUGAS_TIERRA" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>
	
				<prop name="MAP_LITERAL_FUGAS_TIERRA" disablevisible="MAP_VER_FUGAS_TIERRA_OT&gt;0" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="TL" title="  Sin fugas a tierra  " width="100%" height="15p"	align="left" lines="1" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
	
				<prop name="MAP_FUGAS_TIERRA" content="@FUGAS_TIERRA_OT" disablevisible="MAP_VER_FUGAS_TIERRA_OT=0" type="Z"/>
				<content name="@FUGAS_TIERRA_OT" src="FUGAS_TIERRA_OT" filter="cab.NUMEROORDEN='##FLD_NUMEROORDEN##'" />	
	
				<break-page />

				<frame name="frmInundabilidad" disablevisible="MAP_VER_INUNDABILIDAD=0" width="100%" tmargin="15p">
					<frame name="frmInundabilidad_2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_INUNDABILIDAD" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>

				<prop name="MAP_INUNDABILIDAD" content="@Inundabilidad" disablevisible="MAP_VER_INUNDABILIDAD=0" type="Z"/>
				<content name="@Inundabilidad" src="Inundabilidad" filter="rev.NUMEROORDEN='##FLD_NUMEROORDEN##'"/>

</coll>
	
	<!-- Riesgos  -->

	<coll name="Riesgos" sql="SELECT 
	'Riesgo' AS MAP_TITLE_RIESG,
	CONCAT('  ',ri.NUMEROORDEN) AS MAP_NUMEROORDEN,
	CONCAT('  ',ri.COD_TIP_ACCION) AS MAP_COD_TIP_ACCION,
	CONCAT('  ',mri.DESCRIPCION ) AS MAP_DESCRIPCION 
	FROM gen_ar_ot_riesgos ri
	INNER JOIN gen_ar_maestro_riesgos mri ON ri.COD_TIP_RIESGO = mri.COD_TIP_RIESGO"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmACR" width="100%" tmargin="15p">
			<frame name="frmTITLE_RIESG" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
				<prop name="MAP_TITLE_RIESG" type="T" width="98%" height="15p" align="center"
						bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
			</frame>
		</frame>
		
		<prop name="MAP_TL_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Número de Orden  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
		
		<prop name="MAP_TL_COD_TIP_ACCION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  ACCIÓN  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_COD_TIP_ACCION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
		
		<prop name="MAP_TL_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  RIESGO  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
		
	</coll> 	
	


	<!-- Robos  -->
	<coll name="Robos_OT" sql="select cab.NUMEROORDEN, cab.CLASE_ORDEN, cab.CLASE_ACTIVIDAD, cab.UBICACION_TECNICA,
		concat('  ',rob.COD_ROBO) as MAP_TIPOROBO,
		rob.NUMEROORDEN,
		'Robos' as MAP_TITLE_Robos_OT,
		concat('  ',CASE WHEN rob.NUM_SERIE = '0' THEN 'N/A' ELSE rob.NUM_SERIE END) as MAP_NUM_SERIE_ROBO,
		concat('  ',CASE WHEN rob.MARCA = '0' THEN 'N/A' ELSE rob.MARCA END) as MAP_MARCA_ROBO,		
		concat('  ',rob.DESCRIPCION) as MAP_DESCRI_ROBO,
		concat('  ',rob.FECHA) as MAP_FECHA_ROBO,
		rob.FNO_EQ,
		rob.FID_EQ 

		from gen_ot_cabecera cab
			INNER JOIN gen_rob_ot_robos rob ON rob.NUMEROORDEN=cab.NUMEROORDEN 
		" lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmRobo" width="100%" tmargin="15p">
			<frame name="frmTITLE_Robos_OT" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
				<prop name="MAP_TITLE_Robos_OT" type="T" width="98%" height="15p" align="center"
						bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
			</frame>
		</frame>
		
		<prop name="MAP_TL_TIPOROBO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Tipo robo  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_TIPOROBO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
		
		<prop name="MAP_TL_DESCRI_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Descripción de robo  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_DESCRI_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
		
		<prop name="MAP_TL_MARCA_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Marca  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_MARCA_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
		
		<prop name="MAP_TL_NUM_SERIE_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Número de serie  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_NUM_SERIE_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
		
		<prop name="MAP_TL_FECHA_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Fecha robo  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
		<prop name="MAP_FECHA_ROBO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
	</coll> 
	
	
	
	<!-- Fugas a tierra  -->
	<coll name="FUGAS_TIERRA_OT" sql="SELECT cab.NUMEROORDEN, 'Fugas a tierra' as MAP_TITLE_FUGAS_TIERRA_OT, concat('  ',fug.FECHA_CARGA) as MAP_FECHA_CARGA, 
		concat('  ',fug.NUM_AVISO) as MAP_NUM_AVISO, concat('  ',fug.UBICACION_TECNICA) as MAP_CODIGO_INSTALACION, concat('  ',fug.DESCRIPCION) as MAP_DESCRIPCION_FUGA_TIERRA, 
		concat('  ',fug.TIPO_FUGA) as MAP_TIPO_FUGA, concat('  ',fug.CORRIENTE_FUG_PREV) as MAP_CORRIENTE_FUG_PREV, concat('  ',fug.FECHA_VERIF) as MAP_FECHA_VERIF, 
		concat('  ',fug.CORRIENTE_FUG_PREV) as MAP_CORRIENTE_FUG_PREV, concat('  ',fug.FECHA_VERIF) as MAP_FECHA_VERIF, concat('  ',fug.CORRIENTE_FUG_REAL) as MAP_CORRIENTE_FUG_REAL, 
		concat('  ',fug.CONTADOR) as MAP_CONTADOR, concat('  ',fug.DEFECT_LOCALIZADO) as MAP_DEFECT_LOCALIZADO, concat('  ',fug.DEFECT_CORREGIDO) as MAP_DEFECT_CORREGIDO,
		concat('  ',fug.ORIGEN_FUGA) as MAP_ORIGEN_FUGA, concat('  ',fug.TIPO_CLIENTE) as MAP_TIPO_CLIENTE, concat('  ',fug.TIPO_USO) as MAP_TIPO_USO, 
		concat('  ',fug.CAUSA_FUGA) as MAP_CAUSA_FUGA, concat('  ',fug.ESTADO_FUGA) as MAP_ESTADO_FUGA
		FROM gen_avf_ot_fugas_tierra fug 
			INNER JOIN gen_ot_cabecera cab ON cab.NUMEROORDEN = fug.NUMEROORDEN" lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmFugaTierra" width="100%" tmargin="15p">
			<frame name="frmTITLE_FUGAS_TIERRA_OT" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
				<prop name="MAP_TITLE_FUGAS_TIERRA_OT" type="T" width="98%" height="15p" align="center"
						bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
			</frame>
		</frame>
		
		<prop name="MAP_TL_FECHA_CARGA" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Fecha carga  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
