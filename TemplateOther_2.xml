<?xml version="1.0" encoding="utf-8"?> 
<xml>
	<!-- CABECERA -->				
	<coll name="coll1" sql="select CONCAT('  ',O.NUMEROORDEN) AS MAP_NUMEROORDEN,
	CONCAT('  ',O.DESCRIPCION) AS MAP_DESCRIPCION,
	CONCAT('  ',O.OBSERVACIONES) AS MAP_OBSERVACIONES,
						concat('RESUMEN OT - ',O.NUMEROORDEN) AS MAP_TITULO,
						'/var/www/vhosts/xoneideintcore.com/core/xonemonitorcore/Monitor/ide_iberdrola.png' AS MAP_LOGO,
                        O.ID as ID,
						O.NUMEROORDEN,
                        IFNULL(O.PDF_CREADO,0) AS PDF_CREADO,
						O.CLAVE_GRUPO_HR,
						O.CONTADOR_GRUPOS_HR,
						concat('  ', O.CLASE_ORDEN,' - ',CO.DESCRIPCION) AS MAP_CLASE_ORDEN,
						concat('  ', O.CLASE_ACTIVIDAD,' - ',CA.DESCRIPCION) AS MAP_CLASE_ACTIVIDAD,
						concat('  ',ROUND(ifnull(H.HORAS_VIAJE_FINALES,0), 2)) AS MAP_HORAS_DESPLAZAMIENTO,
						concat('  ',ROUND(ifnull(H.HORAS_TRABAJO_FINALES,0),2)) AS MAP_HORAS_INTERVENCION,	

						concat('  ',CASE WHEN O.UBICACION_TECNICA IS NOT NULL THEN concat(O.UBICACION_TECNICA,' - ') ELSE '' END,O.NOMBRE_UBICACION) AS MAP_INSTALACION
		
,
		'Estudio de Inundabilidad' AS MAP_TITLE_INUNDABILIDAD,
		(SELECT COUNT(1) FROM gen_inundabilidad_ot_bloques_rev ir
		 WHERE ir.NUMEROORDEN = O.NUMEROORDEN AND ir.revisado = 1
		   AND O.CLASE_ORDEN IN ('DPRP','DPRN')
		   AND O.UBICACION_TECNICA LIKE 'C%') AS MAP_VER_INUNDABILIDAD,
		O.UBICACION_TECNICA AS MAP_UBICACION_TECNICA						from gen_ot_cabecera O
						LEFT JOIN gen_maestro_clase_orden CO ON CO.CODIGO = O.CLASE_ORDEN
						LEFT JOIN (SELECT SUM(HORAS_VIAJE_FINALES) AS HORAS_VIAJE_FINALES,SUM(HORAS_TRABAJO_FINALES) AS HORAS_TRABAJO_FINALES,NUMEROORDEN from gen_ot_estados_ex goee WHERE BAJA=0 GROUP BY NUMEROORDEN) H ON H.NUMEROORDEN = O.NUMEROORDEN
						LEFT JOIN gen_maestro_clase_actividad CA ON CA.CODIGO = O.CLASE_ACTIVIDAD" lmargin="5%" rmargin="5%" tmargin="5%" bmargin="5%" 
				filter="O.ID=##ID## order by O.ID DESC" entry-point="true" show-header="false" show-pagination="true" show-file-date-creation="true"> 
				<footer height="20p">
					<prop name="MAP_TITLE_FOOTER" type="TL" width="98%" height="15p" title="La revisión se ha realizado según lo indicado en el manual técnico MT 2.04.02" align="center" font-size="10" lines="1" forecolor="#000000" lmargin="1%"/>
				</footer>
						
				<prop name="MAP_TITULO" type="T" lmargin="8%" tmargin="5p" width="64%" align="center" fontbold="true" font-size="18" copy-to-all-pages="true"/>
				<prop name="MAP_LOGO" 	type="IMG" 	lmargin="19%" width="9%" align="right"  copy-to-all-pages="true" newline="false" keep-aspect-ratio="true"/>
			
				<frame name="frmDatosIdentificativos" width="100%" border-color="#000000" tmargin="15p">

					<frame name="frmTITLE_DATOS_IDENTIFICACION" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_DATOS_IDENTIFICACION" type="TL" width="98%" height="15p" title="Datos identificativos" align="center" 
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" border-color="#000000" forecolor="#ffffff" lmargin="1%"/>
					</frame>
					
					<prop name="MAP_TL_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Numero de OT:  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
					<prop name="MAP_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
			
					<prop name="MAP_TL_CLASE_ORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Clase de Orden: " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
					<prop name="MAP_CLASE_ORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
					<prop name="MAP_TL_CLASE_ACTIVIDAD" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Clase de Actividad: " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_CLASE_ACTIVIDAD" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>
				
					<prop name="MAP_TL_INSTALACION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Instalacion: " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_INSTALACION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>
					
					<prop name="MAP_TL_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Descripción: " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>
							
					<prop name="MAP_TL_OBSERVACIONES" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Observaciones: " align="center" bgcolor="#ffffff" lines="2" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_OBSERVACIONES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>
					
				</frame>

				<frame name="frmExpedientes" width="100%" tmargin="15p" disablevisible="MAP_EXTERNO=1">
					<frame name="frmEXPEDIENTES" disablevisible="MAP_EXTERNO=1" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_EXPEDIENTES" disablevisible="MAP_EXTERNO=1" type="TL" width="98%" height="15p" title="Expedientes" align="center"
								bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>
				
				<prop name="HorasExpedientes" disablevisible="MAP_EXTERNO=1" content="@HorasExpedientes"  type="Z"/>
				<content name="@HorasExpedientes" src="HorasExpedientes" filter="p.NUMEROORDEN='##FLD_NUMEROORDEN##' ORDER BY FECHA ASC"/>						
				
	
				<break-page />

				<frame name="frmInundabilidad" disablevisible="MAP_VER_INUNDABILIDAD=0" width="100%" tmargin="15p">
					<frame name="frmInundabilidad_2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_INUNDABILIDAD" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>

				<prop name="MAP_INUNDABILIDAD" content="@Inundabilidad" disablevisible="MAP_VER_INUNDABILIDAD=0" type="Z"/>
				<content name="@Inundabilidad" src="Inundabilidad" filter="rev.NUMEROORDEN='##FLD_NUMEROORDEN##'"/>

</coll>	
	
	<coll name="HorasExpedientes" sql="SELECT 
		CONCAT('  ',ROUND(HORAS_VIAJE_FINALES,2)) AS MAP_HORAS_VIAJE_FINALES,
		CONCAT('  ',ROUND(HORAS_TRABAJO_FINALES,2)) AS MAP_HORAS_TRABAJO_FINALES,
		CONCAT('  ',NUMEROORDEN) AS MAP_NUMEROORDEN,
		CONCAT('  ',EXPEDIENTE) AS MAP_EXPEDIENTE,
		CONCAT('  ',FECHA) AS MAP_FECHA
		FROM (SELECT SUM(HORAS_VIAJE_FINALES) AS HORAS_VIAJE_FINALES,SUM(HORAS_TRABAJO_FINALES) AS HORAS_TRABAJO_FINALES,
		NUMEROORDEN,EXPEDIENTE,DATE_FORMAT(FECHA, '%Y-%m-%d') AS FECHA 
		from gen_ot_estados_ex goee WHERE BAJA=0 group by NUMEROORDEN,EXPEDIENTE,DATE_FORMAT(FECHA, '%Y-%m-%d')) p"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmTp2" width="100%" >
			<frame name="frmTITLE_PROPIEDAD2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#ffffff">
				<prop name="MAP_FECHA" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
				<prop name="MAP_EXPEDIENTE" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
				<prop name="MAP_HORAS_VIAJE_FINALES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
				<prop name="MAP_HORAS_TRABAJO_FINALES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
			</frame>
		</frame>
	</coll>

	<!-- Estudio de Inundabilidad -->
	<coll name="Inundabilidad" sql="SELECT
		ct.UBICACION_TECNICA,
		CONCAT('  ', IFNULL(ct.B_INUNDABILIDAD, '')) AS MAP_B_INUNDABILIDAD,
		CONCAT('  ', IFNULL(ct.CAN_ALT_INUND, '')) AS MAP_CAN_ALT_INUND,
		CONCAT('  ', IFNULL(ct.B_INUNDADO, '')) AS MAP_B_INUNDADO,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_SUELO, '')) AS MAP_CAN_ALT_RASANTE_SUELO,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_AGUA, '')) AS MAP_CAN_ALT_RASANTE_AGUA,
		CONCAT('  ', IFNULL(mrv.DESCRIPCION, '')) AS MAP_RIESGO_INUND,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_EQ_STAR, '')) AS MAP_CAN_ALT_RASANTE_EQ_STAR,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_MAN_CEL, '')) AS MAP_CAN_ALT_RASANTE_MAN_CEL,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_CBT, '')) AS MAP_CAN_ALT_RASANTE_CBT
		FROM gen_ct ct
		LEFT JOIN gen_inundabilidad_ot_bloques_rev rev ON rev.G3E_FID = ct.G3E_FID AND rev.G3E_FNO = ct.G3E_FNO
		LEFT JOIN gen_maestrovetipriesgoinundvl mrv ON mrv.COD_TIP_RIESGO_INUND = ct.COD_TIP_RIESGO_INUND"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<prop name="MAP_TL_B_INUNDABILIDAD" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Inundabilidad  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_B_INUNDABILIDAD" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_CAN_ALT_INUND" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Altura inundación ZI100 instalación (cm)  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_CAN_ALT_INUND" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_B_INUNDADO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Inundado previamente  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_B_INUNDADO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_CAN_ALT_RASANTE_SUELO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Altura rasante a cota 0 instalación (cm)  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_CAN_ALT_RASANTE_SUELO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_CAN_ALT_RASANTE_AGUA" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Altura cota 0 instalación a marca agua (cm)  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_CAN_ALT_RASANTE_AGUA" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_RIESGO_INUND" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Riesgo de inundabilidad  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_RIESGO_INUND" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_CAN_ALT_RASANTE_EQ_STAR" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Altura cota 0 instalación a equipos digitales (cm)  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_CAN_ALT_RASANTE_EQ_STAR" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_CAN_ALT_RASANTE_MAN_CEL" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Altura cota 0 instalación a mando/control celdas (cm)  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_CAN_ALT_RASANTE_MAN_CEL" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>

		<prop name="MAP_TL_CAN_ALT_RASANTE_CBT" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Altura cota 0 instalación a cuadro BT (cm)  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
		<prop name="MAP_CAN_ALT_RASANTE_CBT" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="60%" height="15p" align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>

	</coll>
</xml>