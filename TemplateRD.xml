</coll>

	<!-- Acciones Realizadas  -->

	<coll name="AccionesRealizadas" sql="select 
	'Accion realizada' AS MAP_TITLE_ACR,
	CONCAT('  ',ASE.CODIGO_ACCION_FULL) AS MAP_CODIGO_ACCION_FULL,
	CONCAT('  ',ASE.DESCRIPCION_ACCIONES) AS MAP_DESCRIPCION_ACCIONES,
	CONCAT('  ',TE.DES_DESCRIPCION) AS MAP_DES_DESCRIPCION,
	CONCAT('  ',ASE.FECHA) AS MAP_FECHA,
	ifnull(LENGTH(TE.DES_DESCRIPCION),0) AS MAP_VER_TIPO_EQUIPO,
	ASE.ID,ASE.NUMEROORDEN,ASE.CODIGO_ACCION_FULL,
	ASE.DESCRIPCION_ACCIONES,TE.DES_DESCRIPCION 
	from gen_rd_ot_acciones_seleccionadas ASE
	LEFT JOIN gen_maestrovetipeqstarvl TE ON ASE.TIPO_EQUIPO = TE.COD_TIP_EQSTAR"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmACR" width="100%" tmargin="15p">
			<frame name="frmTITLE_ACR" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
				<prop name="MAP_TITLE_ACR" type="T" width="98%" height="15p" align="center"
						bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
			</frame>
		</frame>

