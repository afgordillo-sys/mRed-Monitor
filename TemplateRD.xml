	<!-- Equipos Afectados con sus fotografias -->

	<coll name="EquiposAfectados" sql="SELECT
		@rownum := @rownum + 1 AS MINDEX,
		'Equipo afectado' as MAP_TITLE_EA,
		CONCAT('  ',tip.DES_DESCRIPCION) AS MAP_TIP_DESCRIPCION,
		CONCAT('  ',stip.DES_SUBTIP_EQSTAR) AS MAP_DES_SUBTIP_EQSTAR,
		CONCAT('  ',fab.DES_DESCRIPCION) AS MAP_FAB_DESCRIPCION,
		CONCAT('  ',md.DES_DESCRIPCION) AS MAP_MOD_DESCRIPCION,
		CONCAT('  ',afec.NUM_SERIE) AS MAP_AFEC_NUM_SERIE,
		CONCAT('  ',eq.G3E_FID) AS MAP_G3E_FID,
		eq.G3E_FNO AS MAP_G3E_FNO,
		CONCAT('  ',eq.MID_EQSTAR) AS MAP_MID,
		CONCAT('  ',eq.NUM_MAT_SAP) AS MAP_NUM_MAT_SAP,
		CONCAT('  ',afec.INDICADOR) AS MAP_INDICADOR,
		CONCAT('  ',afec.FEC_SUMI) as MAP_FEC_SUMI,
		CONCAT('  ',afec.num_posicion) as MAP_NUM_POSICION,
		CONCAT('  ',afec.cod_tens_serv_sec) as MAP_COD_TENSION,
		CONCAT('  ',afec.COD_ACCION_FULL) as MAP_COD_ACCION_FULL,

		length(ifnull(afec.IMG_EQUIPO,'')) as MAP_VER_FOTO,
		concat('/var/www/vhosts/xoneideintcore.com/xonerepository/ReplicaFiles/1KEGG99N/',afec.IMG_EQUIPO) as MAP_IMG_EQUIPO,
		CASE WHEN (SELECT COUNT(1) FROM gen_rd_ot_equipos_afectados WHERE NUMEROORDEN = afec.NUMEROORDEN) = @rownum THEN 1 ELSE 0 END AS MAP_ES_ULTIMO,		
		CONCAT('  ',acc.descripcion_acciones) as MAP_DESCRIPCION_ACCIONES,
		acc.fecha

		FROM gen_rd_ot_equipos_afectados afec
		LEFT JOIN (SELECT @rownum := 0) afec_index ON 1=1
		LEFT JOIN  gen_eqstar eq on eq.G3E_FID = afec.G3E_FID and eq.G3E_FNO = afec.G3E_FNO
		JOIN gen_maestrovetipeqstarvl tip ON (afec.TIPO_EQUIPO = tip.COD_TIP_EQSTAR)
		LEFT JOIN gen_maestrovestipeqstarvl stip ON (eq.COD_SUBTIP_EQSTAR  = stip.COD_SUBTIP_EQSTAR )
		JOIN gen_maestrovefabricantstarvl fab ON (afec.COD_FAB_EQSTAR = fab.COD_FAB_EQSTAR)
		JOIN gen_maestrovemodeqstarvl md ON (afec.COD_MOD_EQSTAR = md.COD_MOD_EQSTAR)
		inner join gen_rd_ot_acciones_seleccionadas acc on (acc.CODIGO_ACCION_FULL = afec.COD_ACCION_FULL and acc.NUMEROORDEN=afec.NUMEROORDEN)"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<frame name="frmEA" width="100%" tmargin="15p">
