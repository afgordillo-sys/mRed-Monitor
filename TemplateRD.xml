		CONCAT('  ', IFNULL(ct.B_INUNDADO, '')) AS MAP_B_INUNDADO,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_SUELO, '')) AS MAP_CAN_ALT_RASANTE_SUELO,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_AGUA, '')) AS MAP_CAN_ALT_RASANTE_AGUA,
		CONCAT('  ', IFNULL(mrv.DESCRIPCION, '')) AS MAP_RIESGO_INUND,
