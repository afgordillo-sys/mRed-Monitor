<?xml version="1.0" encoding="utf-8"?>
<xml>
	<!-- CABECERA -->				
	<coll name="coll1" sql="select DISTINCT CONCAT('  ',O.NUMEROORDEN) AS MAP_NUMEROORDEN,
	CONCAT('  ',O.DESCRIPCION) AS MAP_DESCRIPCION,
	CONCAT('  ',O.OBSERVACIONES) AS MAP_OBSERVACIONES,
						CASE WHEN substr(O.PUESTO_TRABAJO,4,1) = 'E' THEN 1 ELSE 0 END AS MAP_EXTERNO,
						'Medición Paso y Contacto - OBLIGATORIA' AS MAP_TITLE_PAT,
						'/var/www/vhosts/xoneideintcore.com/core/xonemonitorcore/Monitor/qr_iberdrola.png' AS MAP_QR,
						concat('RESUMEN OT - ',O.NUMEROORDEN) AS MAP_TITULO,
						'/var/www/vhosts/xoneideintcore.com/core/xonemonitorcore/Monitor/ide_iberdrola.png' AS MAP_LOGO,
                        O.ID as ID,
						O.NUMEROORDEN,
                        IFNULL(O.PDF_CREADO,0) AS PDF_CREADO,
						O.CLAVE_GRUPO_HR,
						O.CONTADOR_GRUPOS_HR,
						CASE WHEN substr(PUESTO_TRABAJO,4,1) = 'E' THEN 1 ELSE 0 END AS MAP_EXTERNO,
						concat('  ', O.CLASE_ORDEN,' - ',CO.DESCRIPCION) AS MAP_CLASE_ORDEN,
						concat('  ', O.CLASE_ACTIVIDAD,' - ',CA.DESCRIPCION) AS MAP_CLASE_ACTIVIDAD,
						
						concat('  ',ROUND(ifnull(H.HORAS_VIAJE_FINALES,0), 2)) AS MAP_HORAS_DESPLAZAMIENTO,
						concat('  ',ROUND(ifnull(H.HORAS_TRABAJO_FINALES,0),2)) AS MAP_HORAS_INTERVENCION,	
						
						concat('  ',CASE WHEN O.UBICACION_TECNICA IS NOT NULL THEN concat(O.UBICACION_TECNICA,' - ') ELSE '' END,O.NOMBRE_UBICACION) AS MAP_INSTALACION,
												
						(select count(*) from gen_ct_medpyc PAT where PAT.NUMEROORDEN=O.NUMEROORDEN) AS MAP_VER_PAT,						
						concat('  CTE',CASE WHEN O.UBICACION_TECNICA IS NOT NULL THEN concat(' - ',O.UBICACION_TECNICA) ELSE '' END) AS MAP_DESCRIPCION_DT7_CT
						
,
		'Estudio de Inundabilidad' AS MAP_TITLE_INUNDABILIDAD,
		(SELECT COUNT(1) FROM gen_inundabilidad_ot_bloques_rev ir
		 WHERE ir.NUMEROORDEN = O.NUMEROORDEN AND ir.revisado = 1
		   AND O.CLASE_ORDEN IN ('DPRP','DPRN')
		   AND O.UBICACION_TECNICA LIKE 'C%') AS MAP_VER_INUNDABILIDAD,
		O.UBICACION_TECNICA AS MAP_UBICACION_TECNICA						from gen_ot_cabecera O
						LEFT JOIN gen_maestro_clase_orden CO ON CO.CODIGO = O.CLASE_ORDEN
						LEFT JOIN gen_maestro_clase_actividad CA ON CA.CODIGO = O.CLASE_ACTIVIDAD
						LEFT JOIN (SELECT SUM(HORAS_VIAJE_FINALES) AS HORAS_VIAJE_FINALES,SUM(HORAS_TRABAJO_FINALES) AS HORAS_TRABAJO_FINALES,NUMEROORDEN from gen_ot_estados_ex goee WHERE BAJA=0 GROUP BY NUMEROORDEN) H ON H.NUMEROORDEN = O.NUMEROORDEN
						" lmargin="5%" rmargin="5%" tmargin="5%" bmargin="5%" 
		  filter="O.ID=##ID## order by O.ID DESC" entry-point="true" show-header="false" show-pagination="true" show-file-date-creation="true"> 
				<footer height="20p">
					<prop name="MAP_TITLE_FOOTER" type="TL" width="98%" height="15p" title="La revisión se ha realizado según lo indicado en el manual técnico MT 2.04.02" align="center" font-size="10" lines="1" forecolor="#000000" lmargin="1%"/>
				</footer>
						
				<prop name="MAP_TITULO" type="T" lmargin="8%" tmargin="5p" width="64%" align="center" fontbold="true" font-size="18" copy-to-all-pages="true"/>
				<prop name="MAP_LOGO" 	type="IMG" 	lmargin="19%" width="9%" align="right"  copy-to-all-pages="true" newline="false" keep-aspect-ratio="true"/>
			
				<frame name="frmDatosIdentificativos" width="100%" border-color="#000000" tmargin="15p">

					<frame name="frmTITLE_DATOS_IDENTIFICACION" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_DATOS_IDENTIFICACION" type="TL" width="98%" height="15p" title="Datos identificativos" align="center" 
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" border-color="#000000" forecolor="#ffffff" lmargin="1%"/>
					</frame>
					
					<prop name="MAP_TL_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Numero de OT:  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
					<prop name="MAP_NUMEROORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />
			
					<prop name="MAP_TL_CLASE_ORDEN" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Clase de Orden: " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
					<prop name="MAP_CLASE_ORDEN" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
					<prop name="MAP_TL_CLASE_ACTIVIDAD" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Clase de Actividad: " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_CLASE_ACTIVIDAD" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>
				
					<prop name="MAP_TL_INSTALACION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Instalacion: " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_INSTALACION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>
				
					<prop name="MAP_TL_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Descripción: " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_DESCRIPCION" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000"/>
							
					<prop name="MAP_TL_OBSERVACIONES" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Observaciones: " align="center" bgcolor="#ffffff" lines="2" font-size="9" text-border-color="#000000"/>
					<prop name="MAP_OBSERVACIONES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1" newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000"/>
					
				</frame>

				<frame name="frmDatosGenerales" width="100%" tmargin="15p">
					<frame name="frmTITLE_DATOS_GENERALES" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_DATOS_GENERALES" type="TL" width="98%" height="15p" title="Datos Generales" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
					
				</frame>

				<prop name="MAP_HOJAS_RUTA" content="@HojasRuta" type="Z" />
				<content name="@HojasRuta" src="HojasRuta" filter="COD_HR='##FLD_CLAVE_GRUPO_HR##' AND CONT_HR='##FLD_CONTADOR_GRUPOS_HR##' AND IFNULL(SUBOPERACION,0) &gt; 0 ORDER BY IFNULL(SUBOPERACION,0) ASC"/>
				
				<prop name="MAP_HR" type="TL" title=" " width="100%" height="2p" bgcolor="#000000" lines="1" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" text-border-top="true" text-border-color="#000000"/>
				
				<prop name="MAP_TITLE_NOTIFICACION" border="true" text-border-left="true" text-border-bottom="true" type="TL" title="  Notificación" width="13%" height="15p" align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
				<prop name="MAP_TL_HORAS_DESPLAZAMIENTO" border="true" text-border-left="true" text-border-bottom="true" type="TL" title="  Horas Desplazamiento " width="23%" height="15p" align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
				<prop name="MAP_HORAS_DESPLAZAMIENTO" border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="64%" height="15p"  align="left" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" newline="false"/>

				<prop name="MAP_TITLE_NOTIFICACION_VACIO" border="true" text-border-left="true" text-border-bottom="true" type="TL" title=" " width="13%" height="15p" align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000"/>
				<prop name="MAP_TL_HORAS_INTERVENCION" border="true" text-border-left="true" text-border-bottom="true" type="TL" title="  Horas Intervencion " width="23%" height="15p" align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
				<prop name="MAP_HORAS_INTERVENCION" border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="64%" height="15p"  align="left" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
				
				<prop name="MAP_HR_2" type="TL" title=" " width="100%" height="2p" bgcolor="#000000" lines="1" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" text-border-top="true" text-border-color="#000000"/>
				
				<!-- <prop name="MAP_TITLE_ETIQUETAS_NUEVAS_USADAS" border="true" text-border-left="true" text-border-bottom="true" type="TL" title="  Etiquetas NFC" width="13%" height="15p" align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
				<prop name="MAP_TL_ETIQUETAS_NUEVAS_USADAS" border="true" text-border-left="true" text-border-bottom="true" type="TL" title="  Nuevas" width="23%" height="15p" align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
				<prop name="MAP_NUM_ETIQUETAS_NUEVAS_USADAS" border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="64%" height="15p"  align="left" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
				-->
				
				<frame name="frmExpedientes" width="100%" tmargin="15p" disablevisible="MAP_EXTERNO=1">
					<frame name="frmEXPEDIENTES" disablevisible="MAP_EXTERNO=1" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_EXPEDIENTES" disablevisible="MAP_EXTERNO=1" type="TL" width="98%" height="15p" title="Expedientes" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>

				</frame>
				
				<prop name="HorasExpedientes" disablevisible="MAP_EXTERNO=1" content="@HorasExpedientes"  type="Z"/>
				<content name="@HorasExpedientes" src="HorasExpedientes" filter="p.NUMEROORDEN='##FLD_NUMEROORDEN##' ORDER BY FECHA ASC"/>
				
				<break-page />

				<prop name="MAP_DESCRIPCION_DT7_CT" type="T" width="96%" height="20p" align="center" lines="1" font-size="10" />
		
				<frame name="frmPat" width="100%" tmargin="15p" disablevisible="MAP_VER_PAT&gt;0">
					<frame name="frmTITLE_PAT" disablevisible="MAP_VER_PAT&gt;0" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_PAT" disablevisible="MAP_VER_PAT&gt;0" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>

				<prop name="MAP_LITERAL_PAT" disablevisible="MAP_VER_PAT&gt;0" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="TL" title="  No realizada" width="100%" height="15p"	align="left" lines="1" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />

				<prop name="MAP_PAT" content="@medpyc"  type="Z"/>
				<content name="@medpyc" src="medpyc" filter="medpyc.NUMEROORDEN='##FLD_NUMEROORDEN##'"/>


	
				<break-page />

				<frame name="frmInundabilidad" disablevisible="MAP_VER_INUNDABILIDAD=0" width="100%" tmargin="15p">
					<frame name="frmInundabilidad_2" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
						<prop name="MAP_TITLE_INUNDABILIDAD" type="T" width="98%" height="15p" align="center"
							  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
					</frame>
				</frame>

				<prop name="MAP_INUNDABILIDAD" content="@Inundabilidad" disablevisible="MAP_VER_INUNDABILIDAD=0" type="Z"/>
				<content name="@Inundabilidad" src="Inundabilidad" filter="rev.NUMEROORDEN='##FLD_NUMEROORDEN##'"/>

</coll>
	
	<!--HOJA DE RUTA -->
	
	<coll name="HojasRuta" sql="SELECT 
						CASE WHEN (@i := @i + 1) % 2 = 0 THEN '#FFFFFF' ELSE '#e3eadf' end MAP_BACKGROUND_COLOR,
						case when @i = 1 then '  Hoja de ruta' else '' end MAP_TITLE,
						concat('  Paso ',@i) as MAP_PASO,
						concat('  ', r.DESCRIPCION) as DESCRIPCION
						FROM gen_operacioneshr  r
						cross join (select @i := 0) r" 
						lmargin="10p" rmargin="10p" tmargin="10p" filter="" entrypoint="true" show-header="false">

			<prop name="MAP_TITLE" border="true" text-border-left="true" text-border-bottom="true" type="T" width="13%" height="15p" align="center" bgcolor="##FLD_MAP_BACKGROUND_COLOR##" lines="1" font-size="9" text-border-color="#000000"/>
			<prop name="MAP_PASO" border="true" text-border-left="true" text-border-bottom="true" type="T" width="23%" height="15p" align="center" bgcolor="##FLD_MAP_BACKGROUND_COLOR##" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
			<prop name="DESCRIPCION" border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="64%" height="15p"  align="left" bgcolor="##FLD_MAP_BACKGROUND_COLOR##" lines="1" font-size="9" text-border-color="#000000" newline="false"/>
	
	</coll>
			
	<!-- PAT  -->
	<coll name="medpyc" sql="SELECT DISTINCT
			ifnull(COD_ANOMALIA,'-') as COD_ANOMALIA,
			medpyc.ANOMALIA_CREADO,
			medpyc.INSTALACION_CONECTADA,
			CONCAT('  ',medpyc.TIPO_EQUIPO_MED,' ',medpyc.CODIGO_EQUIPO_MED) AS MAP_EQUIPO_MED,
			CONCAT('  ',medpyc.RESISTENCIA_TELU) AS MAP_RESISTENCIA_MEDIDA,
			CONCAT('  ',medpyc.RESITENCIA_BUCLE) AS MAP_RESISTENCIA_BUCLE,
			CONCAT('  ',medpyc.RESISTENCIA_PANTALLA) AS MAP_RESISTENCIA_PANTALLA,
			CONCAT('  ',medpyc.RESISTENCIA_ELECTRODO) AS MAP_RESISTENCIA_ELECTRODO,
			CONCAT('  ',medpyc.USU_TMANOPIE,CASE WHEN medpyc.ANOMALIA_TMANOPIE = 1 THEN ' - valor  anómalo ' ELSE ' - valor correcto' END) AS MAP_TENSION_MAX_MP,
			CONCAT('  ',medpyc.USU_TMANOMANO,CASE WHEN medpyc.ANOMALIA_TMANOMANO = 1 THEN ' - valor  anómalo ' ELSE ' - valor correcto' END) AS MAP_TENSION_MAX_MM,
			CONCAT('  ',medpyc.USU_TPASOMD,CASE WHEN medpyc.ANOMALIA_TPASOMD = 1 THEN ' - valor  anómalo ' ELSE ' - valor correcto' END) AS MAP_MAX_TENSION_PASO_MEDIDA,
			
			'Medición Paso y Contacto - OBLIGATORIA' AS MAP_TITLE_PAT
			FROM gen_ct_medpyc medpyc" lmargin="10p" rmargin="10p" tmargin="10p" filter="" entrypoint="true" show-header="false">

			<frame name="frmPat" width="100%" tmargin="15p">
				<frame name="frmTITLE_PAT" border="true" border-left="true" border-bottom="true" border-right="true" border-top="true" border-color="#000000" width="100%" bgcolor="#7b9c66">
					<prop name="MAP_TITLE_PAT" type="T" width="98%" height="15p" align="center"
						  bgcolor="#00000000" font-size="10" lines="1" fontbold="true" forecolor="#ffffff" border-color="#000000" lmargin="1%"/>
				</frame>
			</frame>

			<!--<prop name="MAP_TL_MEDICION_PAT" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Medición PAT  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MEDICION_PAT" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#e3eadf" font-size="9" text-border-color="#000000" />-->
		
			<prop name="MAP_TL_EQUIPO_MED" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Equipo Medición  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_EQUIPO_MED" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />

			<prop name="MAP_TL_RESISTENCIA_MEDIDA" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Resistencia Medida  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_RESISTENCIA_MEDIDA" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />

			<prop name="MAP_TL_RESISTENCIA_BUCLE" disablevisible="INSTALACION_CONECTADA=0" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Rb (Resistencia bucle)  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_RESISTENCIA_BUCLE" disablevisible="INSTALACION_CONECTADA=0" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
			<prop name="MAP_TL_RESISTENCIA_PANTALLA" disablevisible="INSTALACION_CONECTADA=0" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Resistencia a través de las pantallas  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_RESISTENCIA_PANTALLA" disablevisible="INSTALACION_CONECTADA=0" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
			<prop name="MAP_TL_RESISTENCIA_ELECTRODO" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Resistencia del electrodo  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_RESISTENCIA_ELECTRODO" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
			<prop name="MAP_TL_TENSION_MAX_MP" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Tensión de contacto máx (mano-pie)  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_TENSION_MAX_MP" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />
			
			<prop name="MAP_TL_TENSION_MAX_MM" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Tensión de contacto máx (mano-mano)  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_TENSION_MAX_MM" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />

			<prop name="MAP_TL_MAX_TENSION_PASO_MEDIDA" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="30%" height="15p"	title="  Máxima tensión de paso medida  " align="center" bgcolor="#ffffff" lines="1" font-size="9" text-border-color="#000000" />
			<prop name="MAP_MAX_TENSION_PASO_MEDIDA" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="70%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="9" text-border-color="#000000" />

