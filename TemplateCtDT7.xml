	<!-- Estudio de Inundabilidad -->
	<coll name="Inundabilidad" sql="SELECT
		ct.UBICACION_TECNICA,
		CONCAT('  ', CASE WHEN ct.B_INUNDABILIDAD = 1 THEN 'SI' WHEN ct.B_INUNDABILIDAD = 0 THEN 'NO' ELSE '' END) AS MAP_B_INUNDABILIDAD,
		CONCAT('  ', IFNULL(ct.CAN_ALT_INUND, '')) AS MAP_CAN_ALT_INUND,
		CONCAT('  ', CASE WHEN ct.B_INUNDADO = 1 THEN 'SI' WHEN ct.B_INUNDADO = 0 THEN 'NO' ELSE '' END) AS MAP_B_INUNDADO,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_SUELO, '')) AS MAP_CAN_ALT_RASANTE_SUELO,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_AGUA, '')) AS MAP_CAN_ALT_RASANTE_AGUA,
		CONCAT('  ', IFNULL(mrv.DESCRIPCION, '')) AS MAP_RIESGO_INUND,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_EQ_STAR, '')) AS MAP_CAN_ALT_RASANTE_EQ_STAR,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_MAN_CEL, '')) AS MAP_CAN_ALT_RASANTE_MAN_CEL,
		CONCAT('  ', IFNULL(ct.CAN_ALT_RASANTE_CBT, '')) AS MAP_CAN_ALT_RASANTE_CBT
		FROM gen_ct ct
		LEFT JOIN gen_inundabilidad_ot_bloques_rev rev ON rev.G3E_FID = ct.G3E_FID AND rev.G3E_FNO = ct.G3E_FNO
		LEFT JOIN gen_maestrovetipriesgoinundvl mrv ON mrv.COD_TIP_RIESGO_INUND = ct.COD_TIP_RIESGO_INUND"
					lmargin="10p" rmargin="10p" tmargin="10p" filter="" show-header="false">

		<prop name="MAP_TL_B_INUNDABILIDAD" text-border="true" text-border-left="true" text-border-bottom="true" type="TL" width="40%" height="15p" title="  Inundabilidad  " align="center" bgcolor="#e3eadf" lines="1" font-size="9" text-border-color="#000000"/>
