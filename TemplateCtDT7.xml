				<prop name="MAP_HORAS_VIAJE_FINALES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
				<prop name="MAP_HORAS_TRABAJO_FINALES" text-border="true" text-border-left="true" text-border-bottom="true" text-border-right="true" type="T" width="25%" height="15p"	align="left" lines="1"  newline="false" bgcolor="#ffffff" font-size="8" text-border-color="#000000" />
